{
  "manifest_version": 3,
  "name": "FactFox",
  "version": "1.0.0",
  "description": "Detect malicious prompts and verify AI-generated responses.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "FactFox"
  },
  "permissions": ["activeTab", "contextMenus", "scripting"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
